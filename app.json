      "package": "com.notafacil.docente",
      "permissions": [
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.INTERNET"
      ]
    },
    "plugins": ["expo-secure-store"],
    "scheme": "notafacil",
    "extra": {},
    "owner": "sisas"
  }
}
